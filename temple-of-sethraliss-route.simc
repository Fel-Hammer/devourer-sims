# rider patrol
raid_events+=/pull,pull=04,bloodlust=0,delay=013,enemies="sand-sworn-rider_1":4777592|"lightning-serpent_1":2985995:Beast|"poisonous-viper_1":2985995:Beast|"sandswept-hunter_1":3284595|"storm-adept_1":2687396
# snake wing, first packs; the wing is one 26-mob chain in fast runs
raid_events+=/pull,pull=05,bloodlust=0,delay=006,enemies="sand-sworn-rider_1":4777592|"sand-sworn-rider_2":4777592|"lightning-serpent_1":2985995:Beast|"lightning-serpent_2":2985995:Beast|"poisonous-viper_1":2985995:Beast|"poisonous-viper_2":2985995:Beast|"faithless-subjugator_1":2985995|"faithless-subjugator_2":2985995|"brood-tender_1":2985995
