# Temple of Sethraliss — standard Mythic+ dungeon route (Midnight Season 2).
# Reconstructed from 12.1 PTR logs on Warcraft Logs: pull composition, chaining, travel
# times, and per-mob health from a 21-run consensus (+10 to +20 keys). Mob health is the
# logged +15 value scaled to a single actor's share (x0.27, the measured DPS-player share
# of group damage); scale any key with HP(k) = shown x 1.1^(k-15).
# Usage: append to the profile —  simc devourer.simc temple-of-sethraliss-route.simc
# Bloodlust fires on pull 1 and Galvazzt (as logged groups do); the override below turns
# off the fixed-time lust so the per-pull flags decide.
fight_style=DungeonRoute
max_time=3000
vary_combat_length=0
desired_targets=1
override.bloodlust=0

enemy=DungeonRoute_TempleOfSethraliss
enemy_health=999999
raid_events=/invulnerable,cooldown=6000,duration=6000,retarget=1
# entrance pack A; chained into B by fast groups
raid_events+=/pull,pull=01,bloodlust=1,delay=010,enemies="shrouded-fang_1":2985995:Beast|"shrouded-fang_2":2985995:Beast|"shrouded-fang_3":2985995:Beast|"sandswept-hunter_1":3284595|"sandswept-hunter_2":3284595|"sandswept-hunter_3":3284595|"barbed-krolusk_1":2388796:Beast|"barbed-krolusk_2":2388796:Beast|"rogue-krolusk_1":59720:Beast|"rogue-krolusk_2":59720:Beast|"storm-adept_1":2687396|"sandfury-stonefist_1":5374791
# entrance pack B
raid_events+=/pull,pull=02,bloodlust=0,delay=002,enemies="shrouded-fang_1":2985995:Beast|"shrouded-fang_2":2985995:Beast|"sandswept-hunter_1":3284595|"sandswept-hunter_2":3284595|"barbed-krolusk_1":2388796:Beast|"barbed-krolusk_2":2388796:Beast|"rogue-krolusk_1":59720:Beast|"rogue-krolusk_2":59720:Beast|"storm-adept_1":2687396|"storm-adept_2":2687396|"sandfury-stonefist_1":5374791
